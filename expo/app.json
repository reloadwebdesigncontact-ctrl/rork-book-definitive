{
  "expo": {
    "name": "Summshine",
    "slug": "book-definitive",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "coverscan",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF7A00"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.coverscan",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Summshine to access your camera to scan book covers.",
        "NSMicrophoneUsageDescription": "Allow Summshine to access your microphone for audio reading.",
        "NSPhotoLibraryUsageDescription": "Allow Summshine to access your photos to select a book cover."
      }
    },
    "android": {
      "icon": "./assets/images/icon.png",
      "package": "app.coverscan",
      "versionCode": 68,
      "allowBackup": false,
      "blockedPermissions": [],
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Summshine to access your camera to scan book covers.",
          "microphonePermission": "Allow Summshine to access your microphone for audio reading.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Summshine to access your photos to select a book cover."
        }
      ],
      "./plugins/withFixDynamicAppIconJvm.js",
      "./plugins/withFixDynamicAppIcon.js",
      [
        "expo-dynamic-app-icon",
        {
          "orange":    { "image": "./assets/images/icon.png",      "prerendered": true },
          "red":       { "image": "./assets/images/red.png",       "prerendered": true },
          "purple":    { "image": "./assets/images/purple.png",    "prerendered": true },
          "turquoise": { "image": "./assets/images/turquoise.png", "prerendered": true },
          "pink":      { "image": "./assets/images/pink.png",      "prerendered": true },
          "yellow":    { "image": "./assets/images/yellow.png",    "prerendered": true },
          "coral":     { "image": "./assets/images/coral.png",     "prerendered": true },
          "lime":      { "image": "./assets/images/lime.png",      "prerendered": true },
          "sunset":    { "image": "./assets/images/sunset.png",    "prerendered": true },
          "dreamy":    { "image": "./assets/images/dreamy.png",    "prerendered": true },
          "neon":      { "image": "./assets/images/neon.png",      "prerendered": true },
          "flamingo":  { "image": "./assets/images/flamingo.png",  "prerendered": true },
          "aurora":    { "image": "./assets/images/aurora.png",    "prerendered": true },
          "ocean":     { "image": "./assets/images/ocean.png",     "prerendered": true },
          "silver":    { "image": "./assets/images/silver.png",    "prerendered": true },
          "gold":      { "image": "./assets/images/gold.png",      "prerendered": true },
          "tropical":  { "image": "./assets/images/tropical.png",  "prerendered": true }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": "https://rork.com/"
      },
      "eas": {
        "projectId": "81256874-6600-42e5-8c5c-cbb8eaaf7d6f"
      }
    },
    "owner": "reload_10"
  }
}
